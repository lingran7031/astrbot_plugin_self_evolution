                "description": "引流推广关键词",
                "hint": "检测到这些关键词则触发引流推广审核。多值用 | 分隔，留空用默认值。"
            },
            "moderation_refusal_keywords": {
                "type": "list",
                "default": ["无法提供", "无法描述", "无法对此", "无法为", "不适合提供", "不适宜提供", "拒绝", "拒绝传播", "无法总结", "色情", "低俗", "不符合", "不遵守", "无法处理", "无法进行", "不当信息", "不当内容"],
